# Editor configuration: https://editorconfig.org
root = true

# Global defaults
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript (Angular code)
[*.ts]
quote_type = single

# HTML templates
[*.html]
indent_size = 2

# SCSS styles
[*.scss]
indent_size = 2

# JSON files (Angular config files)
[*.json]
indent_size = 2

# Markdown documentation
[*.md]
max_line_length = off
trim_trailing_whitespace = false

# YAML (CI pipelines, GitHub workflows)
[*.yml]
indent_size = 2

# Shell scripts
[*.sh]
end_of_line = lf
insert_final_newline = true