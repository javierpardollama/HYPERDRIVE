package-lock=true
save-exact=true

# Allow necessary build scripts
ignore-scripts=false

# Allow binaries so tools can run
bin-links=true

# Keep HTTPS-only registry
strict-ssl=true
registry=https://registry.npmjs.org/

# Keep optional dependencies disabled if you want
optional=false

# Funding messages off
fund=false

# Peer dependencies: allow modern packages to resolve
legacy-peer-deps=true

# Security audits but not blocking installs
audit=true