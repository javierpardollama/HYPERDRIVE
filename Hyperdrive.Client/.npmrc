# Enforce deterministic installs
package-lock=true
save-exact=true

# Disable all lifecycle scripts by default (preinstall/postinstall)
ignore-scripts=true

# Prevent installing packages with known vulnerabilities
audit=true
audit-level=high

# Only allow HTTPS registry access
strict-ssl=true
registry=https://registry.npmjs.org/

# Disable optional dependencies (common malware vector)
optional=false

# Disable package funding messages (reduces noise)
fund=false

# Prevent npm from executing binaries during install
bin-links=false

# Enforce a clean node_modules structure
legacy-peer-deps=false

# Prevent accidental publishing
private=true
