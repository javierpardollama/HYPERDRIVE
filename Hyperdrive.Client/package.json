{
  "name": "hyperdrive.client",
  "version": "0.0.0",
  "description": "Solution for managing file storage, viewing, and downloading",
  "license": "MIT",
  "keywords": [
    "open-source",
    "csharp",
    "rest-api",
    "angular-material",
    "domain-driven-design",
    "clean-architecture",
    "electron-app",
    "nunit-tests",
    "mit-license",
    "postgresql-database",
    "mongodb-atlas",
