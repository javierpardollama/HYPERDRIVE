  },
  "author": {
    "name": "Javier Pardo",
    "email": ""
  },
  "main": "electron.main.js",
  "scripts": {
    "ng": "ng",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" | node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "web": "ng serve --ssl",
    "desktop": "ng serve --ssl | electron .",
    "dev": "ng build --base-href ./  --configuration development",
    "stg": "ng build --base-href ./  --configuration staging",
    "prod": "ng build --base-href ./ --configuration production",
    "doc": "npx compodoc -p tsconfig.doc.json",
    "forge": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "private": true,
  "dependencies": {
